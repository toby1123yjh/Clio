  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/mozilla__readability": "^0.4.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "3.4.17",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wxt": "^0.19.0"
