    "poc:02-opfs": "echo 'TODO: wire POC-02 runner'",
    "poc:03-fts5": "echo 'TODO: wire POC-03 runner'",
    "poc:04-offscreen-lifecycle": "echo 'TODO: wire POC-04 runner'",
    "poc:05-worker-cpu": "echo 'TODO: wire POC-05 runner'",
    "poc:06-csp": "echo 'TODO: wire POC-06 runner'",
    "poc:10-idb-fallback": "echo 'TODO: wire POC-10 runner'"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.75.4",
    "@earendil-works/pi-ai": "0.75.4",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "react": "18",
    "react-dom": "18",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.6.0"
