{
  "name": "@clio-browser/extension",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Clio Chrome Extension — pure browser, evidence-first knowledge companion.",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "poc": "echo 'POC scripts live under poc/ — run by id, e.g. pnpm poc:01-sqlite-wasm'",
